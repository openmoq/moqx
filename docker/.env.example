# Domain for the relay and Let's Encrypt certificate
DOMAIN=relay.example.com

# Email address for Let's Encrypt registration and renewal notices
CERTBOT_EMAIL=you@example.com

# Relay UDP port
ORLY_PORT=4433

# Admin HTTP port (localhost only)
ORLY_ADMIN_PORT=8000

# Logging: 0=INFO 1=WARNING 2=ERROR 3=FATAL
ORLY_LOG_LEVEL=0

# Verbose/debug level: 0=off, 1-4=increasing detail
# ORLY_VERBOSE=0

